)
plot_future <- ggplot(km_df_future, aes(x = time, y = cum_prob, colour = label, fill = label, text = hover_text)) +
geom_ribbon(aes(ymin = lower, ymax = upper), alpha = 0.2, color = NA) +
geom_step() +
scale_y_continuous(labels = scales::percent, limits = c(0, 1)) +
labs(
x      = "Time (days)",
y      = "PrEP initiation probability",
colour = "Likely to start PrEP",
