km_overall  <- survfit(fit_overall)
km_df_overall <- data.frame(
time     = km_overall$time,
cum_prob = 1 - km_overall$surv,
lower    = 1 - km_overall$upper,
upper    = 1 - km_overall$lower
)
km_df_overall$hover_text <- paste0(
"Time: ", km_df_overall$time, " days<br>",
"PrEP initiation prob: ", round(km_df_overall$cum_prob * 100, 1), "%<br>",
"95% CI: [", round(km_df_overall$lower * 100, 1), "% – ",
round(km_df_overall$upper * 100, 1), "%]"
)
plot_overall <- ggplot(km_df_overall, aes(x = time, y = cum_prob, text = hover_text)) +
geom_ribbon(aes(ymin = lower, ymax = upper), alpha = 0.2, color = NA) +
geom_step() +
scale_y_continuous(labels = scales::percent, limits = c(0, 1)) +
labs(
x    = "Time (days)",
y    = "PrEP initiation probability",
title = "Overall cumulative probability of PrEP initiation"
) +
theme_bw()
p_overall <- ggplotly(plot_overall, tooltip = "text")
# --------------------------------------------------------------------
# 2. By perc_protect
# --------------------------------------------------------------------
fit_protect <- coxph(Surv(timestart, timestop, prep) ~ perc_protect, data = df)
km_protect  <- survfit(fit_protect, newdata = data.frame(perc_protect = levels(df$perc_protect)))
km_df_protect <- data.frame(
time     = rep(km_protect$time, times = ncol(km_protect$surv)),
cum_prob = 1 - c(km_protect$surv),
lower    = 1 - c(km_protect$upper),
upper    = 1 - c(km_protect$lower),
group    = rep(levels(df$perc_protect), each = nrow(km_protect$surv))
)
km_df_protect$label <- rep(c("Higher", "Lower"), each = nrow(km_protect$surv))
km_df_protect$hover_text <- paste0(
"PrEP protection: ", km_df_protect$label, "<br>",
"Time: ", km_df_protect$time, " days<br>",
"PrEP initiation prob: ", round(km_df_protect$cum_prob * 100, 1), "%<br>",
"95% CI: [", round(km_df_protect$lower * 100, 1), "% – ",
round(km_df_protect$upper * 100, 1), "%]"
)
plot_protect <- ggplot(km_df_protect, aes(x = time, y = cum_prob, colour = label, fill = label, text = hover_text)) +
geom_ribbon(aes(ymin = lower, ymax = upper), alpha = 0.2, color = NA) +
geom_step() +
scale_y_continuous(labels = scales::percent, limits = c(0, 1)) +
labs(
x      = "Time (days)",
y      = "PrEP initiation probability",
colour = "PrEP protection perception",
fill   = "PrEP protection perception",
title  = "Cumulative probability of PrEP initiation by protection perception"
) +
scale_colour_discrete(labels = c("Higher", "Lower")) +
scale_fill_discrete(labels = c("Higher", "Lower")) +
theme_bw() +
theme(
legend.position = "bottom",
legend.title    = element_text(size = 10),
legend.text     = element_text(size = 9)
)
p_protect <- ggplotly(plot_protect, tooltip = "text")
# --------------------------------------------------------------------
# 3. By future_prep
# --------------------------------------------------------------------
fit_future <- coxph(Surv(timestart, timestop, prep) ~ future_prep, data = df)
km_future  <- survfit(fit_future, newdata = data.frame(future_prep = levels(df$future_prep)))
km_df_future <- data.frame(
time     = rep(km_future$time, times = ncol(km_future$surv)),
cum_prob = 1 - c(km_future$surv),
lower    = 1 - c(km_future$upper),
upper    = 1 - c(km_future$lower),
