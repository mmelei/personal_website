# --- 1. Load data ---
df <- read_csv("/Users/mele/Documents/Emory/Thesis/data/final_full_set_cohort.csv")
# --- 2. Ensure numeric survival variables (hard‑coerce) ---
df$timestart  <- as.numeric(as.character(df$timestart))
df$timestop   <- as.numeric(as.character(df$timestop))
df$prep       <- as.numeric(as.character(df$prep))
# --- 3. Keep predictors as factors ---
df$stopnever   <- factor(df$stopnever,   levels = c("0", "1"), labels = c("No", "Yes"))
df$perc_protect <- factor(df$perc_protect, levels = c("0", "1"), labels = c("Higher", "Lower"))
df$future_prep  <- factor(df$future_prep,  levels = c("0", "1", "2"), labels = c("Not likely", "Somewhat likely", "Very likely"))
table(df$stopnever, useNA=always)
table(df$stopnever, useNA="always")
table(df$timestart, useNA="always")
# --- 4. Sanity check: show rows and classes ---
message("nrow(df) = ", nrow(df))
message("timestart class: ", class(df$timestart))[10]
message("timestop  class: ", class(df$timestop))[10]
message("prep      class: ", class(df$prep))[10]
# --- 5. Stop if anything is NA (we expect it to be all complete cases) ---
if (any(is.na(df$timestart))) {
stop("timestart has NA values")
}
if (any(is.na(df$timestop))) {
stop("timestop has NA values")
}
if (any(is.na(df$prep))) {
stop("prep has NA values")
}
# --- 1. Overall cumulative probability ---
# Use explicit as.numeric inside Surv to avoid "no non‑missing" error
fit_overall <- coxph(
Surv(as.numeric(timestart), as.numeric(timestop), as.numeric(prep)) ~ 1,
data = df
)
km_overall  <- survfit(fit_overall)
km_df_overall <- data.frame(
time     = km_overall$time,
cum_prob = 1 - km_overall$surv,
lower    = 1 - km_overall$upper,
upper    = 1 - km_overall$lower
)
km_df_overall$hover_text <- paste0(
"Time: ", km_df_overall$time, " days<br>",
"PrEP initiation prob: ", round(km_df_overall$cum_prob * 100, 1), "%<br>",
"95% CI: [", round(km_df_overall$lower * 100, 1), "% – ",
round(km_df_overall$upper * 100, 1), "%]"
)
plot_overall <- ggplot(km_df_overall, aes(x = time, y = cum_prob, text = hover_text)) +
geom_ribbon(aes(ymin = lower, ymax = upper), alpha = 0.2, color = NA) +
geom_step() +
scale_y_continuous(labels = scales::percent, limits = c(0, 1)) +
labs(
x    = "Time (days)",
y    = "PrEP initiation probability",
title = "Overall cumulative probability of PrEP initiation"
) +
theme_bw()
p_overall <- ggplotly(plot_overall, tooltip = "text")
# --- 2. By perc_protect ---
fit_protect <- coxph(
Surv(as.numeric(timestart), as.numeric(timestop), as.numeric(prep)) ~ perc_protect,
data = df
)
km_protect  <- survfit(fit_protect, newdata = data.frame(perc_protect = levels(df$perc_protect)))
# --- 1. Run model on df directly (no df_mod) ---
if (any(is.na(df$timestart))) {
stop("timestart has NA in forest‑plot")
}
if (any(is.na(df$timestop))) {
stop("timestop has NA in forest‑plot")
}
if (any(is.na(df$prep))) {
stop("prep has NA in forest‑plot")
}
cox_model <- coxph(
Surv(as.numeric(timestart), as.numeric(timestop), as.numeric(prep)) ~
stopnever + perc_protect + future_prep +
educ2 + ins2 + incomenew +
race2 + site + rand_assign_text,
data = df
)
# --- 2. Build plot_data ---
model_sum <- summary(cox_model)
plot_data <- data.frame(
Variable = rownames(model_sum$conf.int),
HR       = model_sum$conf.int[, 1],
Lower    = model_sum$conf.int[, 3],
Upper    = model_sum$conf.int[, 4],
PVal     = model_sum$coefficients[, 5]
)
# --- 3. IMB labels and HoverText ---
plot_data$Category <- case_when(
grepl("stopnever",    plot_data$Variable) ~ "Information",
grepl("perc_protect", plot_data$Variable) ~ "Motivation",
grepl("future_prep",  plot_data$Variable) ~ "Behavioral Skills",
TRUE ~ ""
)
plot_data$CleanLabel <- gsub(
"stopnever|perc_protect|future_prep|educ2|ins2|incomenew|race2|site|rand_assign_text",
"",
plot_data$Variable
)
plot_data$FinalLabel <- ifelse(
plot_data$Category != "",
paste0("<b>", plot_data$Category, ":</b> ", plot_data$CleanLabel),
plot_data$CleanLabel
)
plot_data$FinalLabel <- factor(plot_data$FinalLabel, levels = plot_data$FinalLabel)
plot_data$HoverText <- paste0(
"<b>", plot_data$FinalLabel, "</b><br>",
"Hazard Ratio: ", round(plot_data$HR, 2), "<br>",
"95% CI: [", round(plot_data$Lower, 2), " – ", round(plot_data$Upper, 2), "]<br>",
"P‑value: ", format.pval(plot_data$PVal, digits = 3)
)
# --- 4. Render plotly version of the forest plot ---
output$forest_plot <- renderPlotly({
plot_ly(
plot_data,
x = ~HR, y = ~FinalLabel, type = "scatter", mode = "markers",
text = ~HoverText,
hoverinfo = "text",
marker = list(color = "#2c3e50", size = 10, symbol = "square"),
error_x = list(
type = "data", symmetric = FALSE,
array = ~Upper - HR, arrayminus = ~HR - Lower,
color = "#2c3e50", thickness = 2
)
) %>%
layout(
title = list(text = "<b>Hazard Ratio (IMB Framework)</b>", x = 0.05),
xaxis = list(title = "Hazard Ratio (Log Scale)", type = "log", zeroline = FALSE),
yaxis = list(title = ""),
margin = list(l = 240, r = 30, t = 60, b = 60),
shapes = list(list(
type = "line", x0 = 1, x1 = 1, y0 = -1, y1 = nrow(plot_data),
line = list(color = "red", dash = "dash", width = 1.5)
))
)
})
View(plot_data)
